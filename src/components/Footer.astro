---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner site-wrapper">
    <div class="footer-top">
      <a href="/" class="footer-logo">
        <img src="/aipm-logo.webp" alt="" width="32" height="32" class="footer-logo-img" />
        <span class="footer-logo-text">AIPM<span class="footer-logo-accent">.blog</span></span>
      </a>
      <nav class="footer-nav" aria-label="Footer navigation">
        <a href="/blog">Blog</a>
        <a href="/about">About</a>
        <a href="/rss.xml">RSS</a>
      </nav>
    </div>
    <div class="footer-bottom">
      <p class="footer-copy">&copy; {year} AIPM.blog. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border);
    padding: 3rem 0 2rem;
    margin-top: 5rem;
  }

  .footer-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
    gap: 2rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }
  .footer-logo-img { height: 32px; width: auto; }
  .footer-logo-text {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text);
  }
  .footer-logo-accent { color: var(--accent); }

  .footer-nav {
    display: flex;
    gap: 2rem;
  }
  .footer-nav a {
    font-size: 0.9rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-nav a:hover { color: var(--text); }

  .footer-bottom { border-top: 1px solid var(--border-light); padding-top: 1.5rem; }
  .footer-copy { font-size: 0.85rem; color: var(--text-muted); margin: 0; }

  @media (max-width: 640px) {
    .footer-top { flex-direction: column; align-items: flex-start; gap: 1.25rem; }
    .footer-nav { gap: 1.5rem; }
  }
</style>
