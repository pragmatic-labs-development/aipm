---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featured = posts.find(p => p.data.featured) ?? posts[0];
const rest     = posts.filter(p => p.id !== featured?.id);

const categories = [
  'Getting Started', 'Strategy', 'LLM Development', 'Discovery',
  'Roadmapping', 'Leadership', 'Workflows', 'Systems', 'Delivery', 'Communication'
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>

      <!-- ── Hero ── -->
      <section class="hero site-wrapper">
        <h1 class="hero-title">Learn AI Product Management</h1>
        <p class="hero-subtitle">Guides, tutorials, and frameworks for PMs at every level — from fundamentals to advanced techniques.</p>
      </section>

      <!-- ── Filters ── -->
      <div class="filters-wrap site-wrapper">
        <div class="filters" id="filters">
          <button class="filter-tag active" data-filter="all">All</button>
          {categories.map(cat => (
            <button class="filter-tag" data-filter={cat}>{cat}</button>
          ))}
        </div>
      </div>

      <!-- ── Stories ── -->
      <section class="stories site-wrapper" id="stories">
        <div class="stories-grid" id="storiesGrid">

          <!-- Featured card -->
          {featured && (
            <a
              href={`/blog/${featured.id}/`}
              class="story-card featured-card"
              data-category={featured.data.category ?? ''}
            >
              {featured.data.heroImage && (
                <div class="story-card-image featured-image">
                  <Image
                    src={featured.data.heroImage}
                    alt={featured.data.title}
                    width={800}
                    height={520}
                    class="card-img"
                  />
                </div>
              )}
              <div class="story-card-content">
                <div class="featured-label"><span>Featured</span></div>
                {featured.data.category && (
                  <span class="story-card-tag">{featured.data.category}</span>
                )}
                <h2 class="story-card-title featured-title">{featured.data.title}</h2>
                <p class="story-card-excerpt">{featured.data.description}</p>
                <div class="story-card-meta">
                  <span class="story-card-date">
                    <FormattedDate date={featured.data.pubDate} />
                  </span>
                  {featured.data.readTime && (
                    <span class="story-card-read-time">{featured.data.readTime}</span>
                  )}
                </div>
              </div>
            </a>
          )}

          <!-- Regular cards -->
          {rest.map(post => (
            <a
              href={`/blog/${post.id}/`}
              class="story-card"
              data-category={post.data.category ?? ''}
            >
              {post.data.heroImage && (
                <div class="story-card-image">
                  <Image
                    src={post.data.heroImage}
                    alt={post.data.title}
                    width={480}
                    height={300}
                    class="card-img"
                  />
                </div>
              )}
              <div class="story-card-content">
                {post.data.category && (
                  <span class="story-card-tag">{post.data.category}</span>
                )}
                <h3 class="story-card-title">{post.data.title}</h3>
                <p class="story-card-excerpt">{post.data.description}</p>
                <div class="story-card-meta">
                  <span class="story-card-date">
                    <FormattedDate date={post.data.pubDate} />
                  </span>
                  {post.data.readTime && (
                    <span class="story-card-read-time">{post.data.readTime}</span>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>

        <p class="no-results" id="noResults" style="display:none">
          No posts in this category yet.
        </p>
      </section>

      <!-- ── Newsletter ── -->
      <section class="newsletter" id="newsletter">
        <div class="newsletter-inner site-wrapper">
          <h2 class="newsletter-title">Get insights delivered</h2>
          <p class="newsletter-desc">Weekly perspectives on AI Product Management. No fluff, just practical lessons.</p>
          <form class="newsletter-form" onsubmit="return false;">
            <input type="email" placeholder="you@example.com" required aria-label="Email address" />
            <button type="submit">Subscribe</button>
          </form>
        </div>
      </section>

    </main>
    <Footer />

    <script>
      const btns  = document.querySelectorAll<HTMLButtonElement>('.filter-tag');
      const cards = document.querySelectorAll<HTMLElement>('.story-card');
      const noResults = document.getElementById('noResults')!;

      btns.forEach(btn => {
        btn.addEventListener('click', () => {
          btns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          const filter = btn.dataset.filter ?? 'all';
          let visible = 0;
          cards.forEach(card => {
            const match = filter === 'all' || card.dataset.category === filter;
            (card as HTMLElement).style.display = match ? '' : 'none';
            if (match) visible++;
          });
          noResults.style.display = visible === 0 ? '' : 'none';
        });
      });
    </script>
  </body>
</html>

<style>
  /* ── Hero ── */
  .hero {
    padding: 4rem 0 3rem;
    max-width: var(--max-width);
  }
  .hero-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }
  .hero-subtitle {
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--text-secondary);
    max-width: 640px;
    line-height: 1.6;
    margin: 0;
  }

  /* ── Filters ── */
  .filters-wrap {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2.5rem;
  }
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .filter-tag {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 0.35rem 0.9rem;
    cursor: pointer;
    transition: all 0.15s ease;
    white-space: nowrap;
  }
  .filter-tag:hover {
    border-color: var(--text-muted);
    color: var(--text);
  }
  .filter-tag.active {
    background: var(--text);
    border-color: var(--text);
    color: var(--bg);
  }
  [data-theme="dark"] .filter-tag.active { color: #1a1a1a; }

  /* ── Stories grid ── */
  .stories { padding-bottom: 2rem; }
  .stories-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.75rem;
  }

  /* ── Base card ── */
  .story-card {
    display: flex;
    flex-direction: column;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }
  .story-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .story-card-image {
    aspect-ratio: 16/10;
    overflow: hidden;
  }
  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .story-card:hover .card-img { transform: scale(1.03); }

  .story-card-content {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .story-card-title {
    font-size: 1.375rem;
    font-weight: 500;
    line-height: 1.3;
    color: var(--text);
    margin: 0 0 0.6rem;
  }

  .story-card-excerpt {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0 0 1rem;
    flex: 1;
  }

  .story-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: auto;
  }
  .story-card-date,
  .story-card-read-time {
    font-size: 0.8125rem;
    color: var(--text-muted);
  }
  .story-card-read-time::before { content: '·'; margin-right: 0.75rem; }

  /* ── Featured card ── */
  .featured-card {
    grid-column: span 3;
    flex-direction: row;
  }

  .featured-image {
    flex: 1.4;
    aspect-ratio: unset;
    min-height: 320px;
  }

  .featured-card .story-card-content {
    flex: 1;
    padding: 2.5rem;
    justify-content: center;
  }

  .featured-label {
    margin-bottom: 0.75rem;
  }
  .featured-label span {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.2rem 0.55rem;
  }

  .featured-title {
    font-size: 2rem !important;
    line-height: 1.2 !important;
    margin-bottom: 0.85rem !important;
  }

  .featured-card .story-card-excerpt {
    -webkit-line-clamp: 4;
    font-size: 1rem;
  }

  /* ── No results ── */
  .no-results {
    grid-column: span 4;
    text-align: center;
    color: var(--text-muted);
    padding: 3rem 0;
    font-size: 1rem;
  }

  /* ── Newsletter ── */
  .newsletter {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border);
    margin-top: 4rem;
  }
  .newsletter-inner {
    padding-top: 4rem;
    padding-bottom: 4rem;
    max-width: 560px;
  }
  .newsletter-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    margin-bottom: 0.6rem;
  }
  .newsletter-desc {
    font-size: 1.0625rem;
    color: var(--text-secondary);
    margin-bottom: 1.75rem;
  }
  .newsletter-form {
    display: flex;
    gap: 0.5rem;
  }
  .newsletter-form input {
    flex: 1;
    font-family: 'Source Sans 3', sans-serif;
    font-size: 1rem;
    padding: 0.65rem 1rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--bg);
    color: var(--text);
    outline: none;
    transition: border-color 0.2s;
  }
  .newsletter-form input:focus { border-color: var(--accent); }
  .newsletter-form button {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.65rem 1.5rem;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s;
  }
  .newsletter-form button:hover { background: var(--accent-hover); }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .stories-grid { grid-template-columns: repeat(3, 1fr); }
    .featured-card { grid-column: span 3; }
  }
  @media (max-width: 768px) {
    .stories-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
    .featured-card {
      grid-column: span 2;
      flex-direction: column;
    }
    .featured-image {
      flex: unset;
      aspect-ratio: 16/10;
      min-height: unset;
    }
    .featured-card .story-card-content { padding: 1.5rem; }
    .featured-title { font-size: 1.5rem !important; }
    .newsletter-form { flex-direction: column; }
  }
  @media (max-width: 480px) {
    .stories-grid { grid-template-columns: 1fr; }
    .featured-card { grid-column: span 1; }
    .hero-subtitle { font-size: 1.0625rem; }
  }
</style>
