---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner site-wrapper">
    <a href="/" class="footer-logo" aria-label="AIPM.blog home">
      <img src="/aipm-logo.webp" alt="AIPM.blog" class="footer-logo-img" height="40" width="auto" />
    </a>

    <nav class="footer-links" aria-label="Footer navigation">
      <a href="https://twitter.com" target="_blank" rel="noopener noreferrer">Twitter</a>
      <span class="footer-sep">|</span>
      <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <span class="footer-sep">|</span>
      <a href="/rss.xml">RSS</a>
    </nav>

    <p class="footer-copy">© {year} AIPM.blog. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 2rem;
    padding-bottom: 2rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--transition);
  }
  .footer-logo:hover { color: var(--text-primary); }

  .footer-logo-img {
    height: 40px;
    width: auto;
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .footer-links a {
    font-size: 0.875rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--transition);
  }
  .footer-links a:hover { color: var(--text-primary); }
  .footer-sep {
    color: var(--text-muted);
    font-size: 0.875rem;
    opacity: 0.4;
  }

  .footer-copy {
    width: 100%;
    text-align: center;
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin-top: 1rem;
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .footer-inner {
      padding-top: 1.5rem;
      padding-bottom: 1.5rem;
      flex-direction: column;
      text-align: center;
    }
    .footer-logo { justify-content: center; }
    .footer-logo-img { height: 36px; }
    .footer-links { justify-content: center; }
    .footer-copy { margin-top: 0.5rem; }
  }
</style>
