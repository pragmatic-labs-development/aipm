---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featured = posts.find(p => p.data.featured) ?? posts[0];
const rest     = posts.filter(p => p.id !== featured?.id);

const categories = [
  'Getting Started', 'Strategy', 'LLM Development', 'Discovery',
  'Roadmapping', 'Leadership', 'Workflows', 'Systems', 'Delivery',
  'Communication', 'AI-Augmented Products', 'Reviews', 'Case Studies'
];

const gradients = [
  'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
  'linear-gradient(135deg, #f093fb 0%, #f5576c 100%)',
  'linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)',
  'linear-gradient(135deg, #43e97b 0%, #38f9d7 100%)',
  'linear-gradient(135deg, #fa709a 0%, #fee140 100%)',
  'linear-gradient(135deg, #a8edea 0%, #fed6e3 100%)',
  'linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%)',
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>

      <!-- ── Hero ── -->
      <section class="hero site-wrapper">
        <h1 class="hero-title">Learn AI Product Management</h1>
        <p class="hero-subtitle">Guides, tutorials, and frameworks for PMs at every level — from fundamentals to advanced techniques.</p>
      </section>

      <!-- ── Filters ── -->
      <div class="filters site-wrapper">
        <button class="filter-tag active" data-filter="all">All</button>
        {categories.map(cat => (
          <button class="filter-tag" data-filter={cat}>{cat}</button>
        ))}
      </div>

      <!-- ── Stories ── -->
      <section class="stories-section site-wrapper" id="stories">
        <div class="stories-grid" id="storiesGrid">

          <!-- Featured card -->
          {featured && (
            <a
              href={`/blog/${featured.id}/`}
              class="story-card featured-card"
              data-category={featured.data.category ?? ''}
            >
              <div class="story-card-image featured-image">
                {featured.data.heroImage ? (
                  <Image
                    src={featured.data.heroImage}
                    alt={featured.data.title}
                    width={800}
                    height={520}
                    class="card-img"
                  />
                ) : (
                  <div class="gradient-placeholder" style={`background: ${gradients[0]};`}></div>
                )}
              </div>
              <div class="story-card-content">
                <div class="featured-label">Featured</div>
                {featured.data.category && (
                  <span class="story-card-tag">{featured.data.category}</span>
                )}
                <h2 class="story-card-title featured-title">{featured.data.title}</h2>
                <p class="story-card-excerpt">{featured.data.description}</p>
                <div class="story-card-meta">
                  <span class="story-card-date">
                    <FormattedDate date={featured.data.pubDate} />
                  </span>
                  {featured.data.readTime && (
                    <span class="story-card-read-time">{featured.data.readTime}</span>
                  )}
                </div>
              </div>
            </a>
          )}

          <!-- Regular cards -->
          {rest.map((post, i) => (
            <a
              href={`/blog/${post.id}/`}
              class="story-card"
              data-category={post.data.category ?? ''}
            >
              <div class="story-card-image">
                {post.data.heroImage ? (
                  <Image
                    src={post.data.heroImage}
                    alt={post.data.title}
                    width={480}
                    height={300}
                    class="card-img"
                  />
                ) : (
                  <div class="gradient-placeholder" style={`background: ${gradients[(i + 1) % gradients.length]};`}></div>
                )}
              </div>
              <div class="story-card-content">
                {post.data.category && (
                  <span class="story-card-tag">{post.data.category}</span>
                )}
                <h3 class="story-card-title">{post.data.title}</h3>
                <p class="story-card-excerpt">{post.data.description}</p>
                <div class="story-card-meta">
                  <span class="story-card-date">
                    <FormattedDate date={post.data.pubDate} />
                  </span>
                  {post.data.readTime && (
                    <span class="story-card-read-time">{post.data.readTime}</span>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>

        <p class="no-results" id="noResults" style="display:none">
          No posts in this category yet.
        </p>
      </section>

      <!-- ── Newsletter ── -->
      <section class="newsletter" id="newsletter">
        <div class="newsletter-inner">
          <h2 class="newsletter-title">Get insights delivered</h2>
          <p class="newsletter-desc">Weekly perspectives on AI Product Management. No fluff, just practical lessons.</p>
          <form class="newsletter-form" onsubmit="return false;">
            <input type="email" placeholder="Your email" required aria-label="Email address" />
            <button type="submit">Subscribe</button>
          </form>
        </div>
      </section>

    </main>
    <Footer />

    <script>
      const btns  = document.querySelectorAll<HTMLButtonElement>('.filter-tag');
      const cards = document.querySelectorAll<HTMLElement>('.story-card');
      const noResults = document.getElementById('noResults')!;

      btns.forEach(btn => {
        btn.addEventListener('click', () => {
          btns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          const filter = btn.dataset.filter ?? 'all';
          let visible = 0;
          cards.forEach(card => {
            const match = filter === 'all' || card.dataset.category === filter;
            (card as HTMLElement).style.display = match ? '' : 'none';
            if (match) visible++;
          });
          noResults.style.display = visible === 0 ? '' : 'none';
        });
      });
    </script>
  </body>
</html>

<style>
  /* ── Hero ── */
  .hero {
    padding: 4rem 0 3rem;
    max-width: var(--max-width);
  }
  .hero-title {
    font-family: 'Newsreader', Georgia, serif;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.15;
    max-width: 700px;
    margin-bottom: 1.25rem;
  }
  .hero-subtitle {
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--text-secondary);
    max-width: 600px;
    line-height: 1.6;
    margin: 0;
  }

  /* ── Filters ── */
  .filters {
    padding-bottom: 2rem;
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .filter-tag {
    padding: 0.5rem 1rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 100px;
    font-size: 0.875rem;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all var(--transition);
    white-space: nowrap;
    font-family: 'Source Sans 3', sans-serif;
  }
  .filter-tag:hover,
  .filter-tag.active {
    background: var(--text-primary);
    border-color: var(--text-primary);
    color: white;
  }
  [data-theme="dark"] .filter-tag:hover,
  [data-theme="dark"] .filter-tag.active {
    color: #1a1a1a;
  }

  /* ── Stories grid ── */
  .stories-section {
    padding-bottom: 4rem;
  }
  .stories-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.75rem;
  }

  /* ── Base card ── */
  .story-card {
    background: var(--bg-card);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    transition: all var(--transition);
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
  }
  .story-card:hover {
    border-color: transparent;
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .story-card-image {
    width: 100%;
    aspect-ratio: 16 / 10;
    background: var(--bg-secondary);
    position: relative;
    overflow: hidden;
  }
  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .story-card:hover .card-img { transform: scale(1.03); }

  .gradient-placeholder {
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
  }

  .story-card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .story-card-title {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.375rem;
    font-weight: 500;
    line-height: 1.35;
    letter-spacing: -0.01em;
    margin-bottom: 0.75rem;
    color: var(--text-primary);
  }

  .story-card-excerpt {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  /* ── Featured card ── */
  .featured-card {
    grid-column: span 3;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 0;
    flex-direction: unset;
  }

  .featured-image {
    aspect-ratio: auto;
    height: 100%;
    min-height: 320px;
  }

  .featured-card .story-card-content {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .featured-title {
    font-size: 2rem !important;
    line-height: 1.2 !important;
  }

  .featured-card .story-card-excerpt {
    -webkit-line-clamp: 4;
    font-size: 1rem;
  }

  /* ── No results ── */
  .no-results {
    grid-column: span 4;
    text-align: center;
    color: var(--text-muted);
    padding: 3rem 0;
    font-size: 1rem;
  }

  /* ── Newsletter ── */
  .newsletter {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border);
    padding: 4rem 3rem;
    margin-top: 0;
  }
  .newsletter-inner {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }
  .newsletter-title {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 2rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }
  .newsletter-desc {
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    font-size: 1.0625rem;
  }
  .newsletter-form {
    display: flex;
    gap: 0.75rem;
    max-width: 440px;
    margin: 0 auto;
  }
  .newsletter-form input {
    flex: 1;
    padding: 0.875rem 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 1rem;
    font-family: inherit;
    background: white;
    transition: border-color var(--transition);
  }
  .newsletter-form input:focus {
    outline: none;
    border-color: var(--accent);
  }
  .newsletter-form button {
    padding: 0.875rem 1.5rem;
    background: #1a1a1a;
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    transition: background var(--transition);
    white-space: nowrap;
  }
  .newsletter-form button:hover { background: #484848; }
  [data-theme="dark"] .newsletter-form button {
    background: #ffffff;
    color: #1a1a1a;
  }
  [data-theme="dark"] .newsletter-form button:hover { background: #cccccc; }

  /* ── Responsive ── */
  @media (max-width: 1200px) {
    .stories-grid { grid-template-columns: repeat(3, 1fr); }
    .featured-card {
      grid-column: span 2;
      grid-template-columns: 1.2fr 1fr;
    }
  }
  @media (max-width: 900px) {
    .stories-grid { grid-template-columns: repeat(2, 1fr); }
    .featured-card {
      grid-column: span 2;
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 768px) {
    .hero { padding: 2.5rem 0 2rem; }
    .hero-title { font-size: 2rem; }
    .hero-subtitle { font-size: 1.0625rem; }
    .filters {
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding-bottom: 1.5rem;
    }
    .filters::-webkit-scrollbar { display: none; }
    .filter-tag {
      flex-shrink: 0;
      padding: 0.5rem 0.875rem;
      font-size: 0.8125rem;
    }
    .stories-section { padding-bottom: 3rem; }
    .stories-grid { gap: 1.25rem; }
    .featured-card .story-card-image { min-height: 200px; }
    .featured-card .story-card-content { padding: 1.5rem; }
    .featured-title { font-size: 1.5rem !important; }
    .featured-card .story-card-excerpt { -webkit-line-clamp: 3; }
    .story-card-content { padding: 1.25rem; }
    .story-card-title { font-size: 1.25rem; }
    .newsletter { padding: 3rem 1.5rem; }
    .newsletter-title { font-size: 1.625rem; }
    .newsletter-desc { font-size: 1rem; }
  }
  @media (max-width: 600px) {
    .stories-grid { grid-template-columns: 1fr; }
    .featured-card { grid-column: span 1; }
  }
  @media (max-width: 500px) {
    .newsletter-form { flex-direction: column; }
  }
  @media (max-width: 480px) {
    .hero { padding: 2rem 0 1.5rem; }
    .hero-title { font-size: 1.75rem; line-height: 1.2; }
    .hero-subtitle { font-size: 1rem; }
    .filters { padding-bottom: 1.25rem; gap: 0.5rem; }
    .filter-tag { padding: 0.4rem 0.75rem; font-size: 0.75rem; }
    .stories-section { padding-bottom: 2.5rem; }
    .stories-grid { gap: 1rem; }
    .featured-card .story-card-image { min-height: 180px; }
    .featured-card .story-card-content { padding: 1.25rem; }
    .featured-title { font-size: 1.375rem !important; }
    .story-card-content { padding: 1rem; }
    .story-card-title { font-size: 1.125rem; }
    .story-card-excerpt { font-size: 0.875rem; -webkit-line-clamp: 2; }
  }
</style>
