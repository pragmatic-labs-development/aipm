---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categories = [
  'Getting Started', 'Strategy', 'LLM Development', 'Discovery',
  'Roadmapping', 'Leadership', 'Workflows', 'Systems', 'Delivery',
  'Communication', 'AI-Augmented Products', 'Reviews', 'Case Studies'
];

const gradients = [
  'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
  'linear-gradient(135deg, #f093fb 0%, #f5576c 100%)',
  'linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)',
  'linear-gradient(135deg, #43e97b 0%, #38f9d7 100%)',
  'linear-gradient(135deg, #fa709a 0%, #fee140 100%)',
  'linear-gradient(135deg, #a8edea 0%, #fed6e3 100%)',
  'linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%)',
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Blog — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="blog-hero site-wrapper">
        <h1 class="hero-title">All Posts</h1>
        <p class="hero-subtitle">Practical guides and frameworks for AI product management.</p>
      </section>

      <div class="filters site-wrapper">
        <button class="filter-tag active" data-filter="all">All</button>
        {categories.map(cat => (
          <button class="filter-tag" data-filter={cat}>{cat}</button>
        ))}
      </div>

      <section class="stories-section site-wrapper">
        <div class="stories-grid" id="storiesGrid">
          {posts.map((post, i) => (
            <a
              href={`/blog/${post.id}/`}
              class="story-card"
              data-category={post.data.category ?? ''}
            >
              <div class="story-card-image">
                {post.data.heroImage ? (
                  <Image
                    src={post.data.heroImage}
                    alt={post.data.title}
                    width={480}
                    height={300}
                    class="card-img"
                  />
                ) : (
                  <div class="gradient-placeholder" style={`background: ${gradients[i % gradients.length]};`}></div>
                )}
              </div>
              <div class="story-card-content">
                {post.data.category && (
                  <span class="story-card-tag">{post.data.category}</span>
                )}
                <h3 class="story-card-title">{post.data.title}</h3>
                <p class="story-card-excerpt">{post.data.description}</p>
                <div class="story-card-meta">
                  <span class="story-card-date">
                    <FormattedDate date={post.data.pubDate} />
                  </span>
                  {post.data.readTime && (
                    <span class="story-card-read-time">{post.data.readTime}</span>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
        <p class="no-results" id="noResults" style="display:none">
          No posts in this category yet.
        </p>
      </section>
    </main>
    <Footer />

    <script>
      const btns  = document.querySelectorAll<HTMLButtonElement>('.filter-tag');
      const cards = document.querySelectorAll<HTMLElement>('.story-card');
      const noResults = document.getElementById('noResults')!;

      btns.forEach(btn => {
        btn.addEventListener('click', () => {
          btns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          const filter = btn.dataset.filter ?? 'all';
          let visible = 0;
          cards.forEach(card => {
            const match = filter === 'all' || card.dataset.category === filter;
            (card as HTMLElement).style.display = match ? '' : 'none';
            if (match) visible++;
          });
          noResults.style.display = visible === 0 ? '' : 'none';
        });
      });
    </script>
  </body>
</html>

<style>
  .blog-hero {
    padding-top: 4.5rem;
    padding-bottom: 3rem;
  }
  .hero-title {
    font-family: 'Newsreader', Georgia, serif;
    font-size: clamp(2.25rem, 4vw, 3.25rem);
    font-weight: 500;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin-bottom: 0.875rem;
  }
  .hero-subtitle {
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .filters {
    padding-bottom: 2rem;
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .filter-tag {
    padding: 0.5rem 1rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 100px;
    font-size: 0.875rem;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all var(--transition);
    white-space: nowrap;
    font-family: 'Source Sans 3', sans-serif;
  }
  .filter-tag:hover,
  .filter-tag.active {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
    transform: scale(1.04);
  }

  .stories-section {
    padding-bottom: 4rem;
  }
  .stories-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.75rem;
  }

  .story-card {
    background: var(--bg-card);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    transition: all var(--transition);
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
  }
  .story-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-3px);
  }

  .story-card-image {
    width: 100%;
    aspect-ratio: 16 / 10;
    background: var(--bg-secondary);
    position: relative;
    overflow: hidden;
  }
  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .story-card:hover .card-img { transform: scale(1.03); }

  .gradient-placeholder {
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
  }

  .story-card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .story-card-title {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.375rem;
    font-weight: 500;
    line-height: 1.35;
    letter-spacing: -0.01em;
    margin-bottom: 0.75rem;
    color: var(--text-primary);
  }

  .story-card-excerpt {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .no-results {
    text-align: center;
    color: var(--text-muted);
    padding: 3rem 0;
    font-size: 1rem;
  }

  @media (max-width: 1200px) { .stories-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 900px)  { .stories-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) {
    .stories-grid { gap: 1.25rem; }
    .story-card-content { padding: 1.25rem; }
    .story-card-title { font-size: 1.25rem; }
  }
  @media (max-width: 600px)  { .stories-grid { grid-template-columns: 1fr; } }
  @media (max-width: 480px) {
    .stories-grid { gap: 1rem; }
    .story-card-content { padding: 1rem; }
    .story-card-title { font-size: 1.125rem; }
    .story-card-excerpt { font-size: 0.875rem; -webkit-line-clamp: 2; }
  }
</style>
