---
import { SITE_TITLE } from '../consts';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner site-wrapper">
    <div class="footer-brand">
      <span class="footer-logo">{SITE_TITLE}</span>
      <p class="footer-tagline">Practical AI for Product Managers</p>
    </div>
    <nav class="footer-nav" aria-label="Footer navigation">
      <a href="/blog">Blog</a>
      <a href="/about">About</a>
    </nav>
    <p class="footer-copy">&copy; {year} AIPM. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 5rem;
    border-top: 1px solid var(--border);
    padding: 3rem 0;
    background: var(--bg-secondary);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: 2rem;
  }

  .footer-logo {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text);
    display: block;
    margin-bottom: 0.25rem;
  }

  .footer-tagline {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin: 0;
  }

  .footer-nav {
    display: flex;
    gap: 1.75rem;
  }
  .footer-nav a {
    font-size: 0.9rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-nav a:hover { color: var(--text); }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin: 0;
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
    .footer-copy { order: 3; }
  }
</style>
