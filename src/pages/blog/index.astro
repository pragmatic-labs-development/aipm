---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categories = [
  'Getting Started', 'Strategy', 'LLM Development', 'Discovery',
  'Roadmapping', 'Leadership', 'Workflows', 'Systems', 'Delivery', 'Communication'
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Blog — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="blog-hero site-wrapper">
        <h1 class="hero-title">All Posts</h1>
        <p class="hero-subtitle">Practical guides and frameworks for AI product management.</p>
      </section>

      <div class="filters-wrap site-wrapper">
        <div class="filters" id="filters">
          <button class="filter-tag active" data-filter="all">All</button>
          {categories.map(cat => (
            <button class="filter-tag" data-filter={cat}>{cat}</button>
          ))}
        </div>
      </div>

      <section class="stories site-wrapper">
        <div class="stories-grid" id="storiesGrid">
          {posts.map(post => (
            <a
              href={`/blog/${post.id}/`}
              class="story-card"
              data-category={post.data.category ?? ''}
            >
              {post.data.heroImage && (
                <div class="story-card-image">
                  <Image
                    src={post.data.heroImage}
                    alt={post.data.title}
                    width={480}
                    height={300}
                    class="card-img"
                  />
                </div>
              )}
              <div class="story-card-content">
                {post.data.category && (
                  <span class="story-card-tag">{post.data.category}</span>
                )}
                <h3 class="story-card-title">{post.data.title}</h3>
                <p class="story-card-excerpt">{post.data.description}</p>
                <div class="story-card-meta">
                  <span class="story-card-date">
                    <FormattedDate date={post.data.pubDate} />
                  </span>
                  {post.data.readTime && (
                    <span class="story-card-read-time">{post.data.readTime}</span>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
        <p class="no-results" id="noResults" style="display:none">
          No posts in this category yet.
        </p>
      </section>
    </main>
    <Footer />

    <script>
      const btns  = document.querySelectorAll<HTMLButtonElement>('.filter-tag');
      const cards = document.querySelectorAll<HTMLElement>('.story-card');
      const noResults = document.getElementById('noResults')!;

      btns.forEach(btn => {
        btn.addEventListener('click', () => {
          btns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          const filter = btn.dataset.filter ?? 'all';
          let visible = 0;
          cards.forEach(card => {
            const match = filter === 'all' || card.dataset.category === filter;
            (card as HTMLElement).style.display = match ? '' : 'none';
            if (match) visible++;
          });
          noResults.style.display = visible === 0 ? '' : 'none';
        });
      });
    </script>
  </body>
</html>

<style>
  .blog-hero {
    padding: 4rem 0 3rem;
  }
  .hero-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
  }
  .hero-subtitle {
    font-size: 1.125rem;
    color: var(--text-secondary);
    margin: 0;
  }

  .filters-wrap {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2.5rem;
  }
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .filter-tag {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 0.35rem 0.9rem;
    cursor: pointer;
    transition: all 0.15s ease;
    white-space: nowrap;
  }
  .filter-tag:hover { border-color: var(--text-muted); color: var(--text); }
  .filter-tag.active {
    background: var(--text);
    border-color: var(--text);
    color: var(--bg);
  }
  [data-theme="dark"] .filter-tag.active { color: #1a1a1a; }

  .stories { padding-bottom: 4rem; }
  .stories-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.75rem;
  }

  .story-card {
    display: flex;
    flex-direction: column;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }
  .story-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .story-card-image {
    aspect-ratio: 16/10;
    overflow: hidden;
  }
  .card-img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .story-card:hover .card-img { transform: scale(1.03); }

  .story-card-content {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .story-card-title {
    font-size: 1.375rem;
    font-weight: 500;
    line-height: 1.3;
    color: var(--text);
    margin: 0 0 0.6rem;
  }

  .story-card-excerpt {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0 0 1rem;
    flex: 1;
  }

  .story-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: auto;
  }
  .story-card-date,
  .story-card-read-time { font-size: 0.8125rem; color: var(--text-muted); }
  .story-card-read-time::before { content: '·'; margin-right: 0.75rem; }

  .no-results {
    text-align: center;
    color: var(--text-muted);
    padding: 3rem 0;
    font-size: 1rem;
  }

  @media (max-width: 1100px) { .stories-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 768px)  { .stories-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; } }
  @media (max-width: 480px)  { .stories-grid { grid-template-columns: 1fr; } }
</style>
