---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category, readTime } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header />
    <main>
      <div class="article-wrap site-wrapper">
        <div class="article-header">
          <a href="/blog" class="back-link">← All Posts</a>

          <div class="article-meta-top">
            {category && <span class="story-card-tag">{category}</span>}
            <div class="meta-details">
              <time class="meta-date"><FormattedDate date={pubDate} /></time>
              {readTime && <span class="meta-read-time">{readTime}</span>}
            </div>
          </div>

          <h1 class="article-title">{title}</h1>
          <p class="article-description">{description}</p>

          {updatedDate && (
            <p class="updated-notice">
              Updated <FormattedDate date={updatedDate} />
            </p>
          )}
        </div>

        {heroImage && (
          <div class="article-hero-image">
            <Image
              src={heroImage}
              alt={title}
              width={1100}
              height={580}
              class="hero-img"
            />
          </div>
        )}

        <div class="article-body">
          <div class="prose">
            <slot />
          </div>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  main { padding-bottom: 5rem; }

  .article-wrap {
    max-width: 800px;
    padding-top: 3rem;
  }

  .article-header { margin-bottom: 2.5rem; }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-muted);
    text-decoration: none;
    margin-bottom: 2rem;
    letter-spacing: 0.01em;
    transition: color var(--transition), gap var(--transition);
  }
  .back-link:hover { color: var(--accent); gap: 0.5rem; }

  .article-meta-top {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .meta-details {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-muted);
  }
  .meta-read-time::before { content: '·'; margin-right: 0.375rem; }

  .article-title {
    font-size: clamp(1.875rem, 4vw, 3rem);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.04em;
    margin: 0 0 1.25rem;
    color: var(--text-primary);
  }

  .article-description {
    font-size: 1.1875rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin: 0;
    max-width: 660px;
  }

  .updated-notice {
    font-size: 0.825rem;
    color: var(--text-muted);
    font-style: italic;
    margin: 0.875rem 0 0;
  }

  .article-hero-image {
    margin-bottom: 3rem;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-md);
  }
  .hero-img { width: 100%; height: auto; display: block; }

  .article-body { max-width: 680px; }

  @media (max-width: 768px) {
    .article-wrap { padding-top: 1.75rem; }
    .article-title { font-size: 1.875rem; }
    .article-description { font-size: 1.0625rem; }
  }
</style>
